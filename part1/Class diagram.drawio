        <mxCell id="NVnYnh1C7RbwFzcAmvRw-13" edge="1" parent="1" source="xa9CocleF6afOvuUqr7u-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" target="TRXBdDGxTs-NISdQ8IEX-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xa9CocleF6afOvuUqr7u-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFF88,#FFFF63);strokeColor=#36393d;fontColor=light-dark(#000000,#000000);" value="The User class represents the user of hBnB. Depending on their purpose, user can be either only customer or host/admin&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Role :&lt;br&gt;Customer = Search/View/Book properties&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Host/Admin =&amp;nbsp;&lt;br&gt;Search/View/Book/List properties&lt;br&gt;&lt;br&gt;Key attributes:&lt;br&gt;is_host&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Key method:&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ validate_user()&lt;/div&gt;&lt;div&gt;+ update_user()&lt;/div&gt;&lt;div&gt;+ delete_user()&lt;br&gt;&lt;br&gt;Explaination of relationship:&lt;br&gt;Place has usage(dependency) relationship with user since the Place class requires the User class to perform its functionality. Place cannot exist without user(host/admin listing properties)&lt;/div&gt;" vertex="1">
          <mxGeometry height="403" width="220" x="170" y="-808" as="geometry" />
        </mxCell>
        <mxCell id="NVnYnh1C7RbwFzcAmvRw-14" edge="1" parent="1" source="xa9CocleF6afOvuUqr7u-3" style="edgeStyle=entityRelationEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1.002;entryY=-0.077;entryDx=0;entryDy=0;entryPerimeter=0;curved=1;" target="TRXBdDGxTs-NISdQ8IEX-30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="xa9CocleF6afOvuUqr7u-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFF88;strokeColor=#d79b00;" value="Services that the host is putting on the page for customer to book&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Role :&lt;br&gt;Display property info (name, type, availability, Amenities, host name, host id&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Key attributes:&lt;br&gt;property_type, available_amenities&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;method:&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;validate_place()&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;update_place()&lt;/div&gt;&lt;br&gt;Explaination of relationship:&lt;br&gt;Bi-direction with review and amenities because the place need amenities to be qualify as place and a review to gain trust from the user. And Both of them need a place to exist.&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="230" x="1382" y="-795" as="geometry" />
        </mxCell>
